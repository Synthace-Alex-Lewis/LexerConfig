{
  "editor.renderWhitespace": "boundary",
  "cmake.configureOnOpen": true,
  "[Log]": {
    "editor.wordWrap": "on"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "cSpell.userWords": [
    "!felid",
    "Behaviour",
    "Centraliser",
    "cmake",
    "colour",
    "colouring",
    "Colours",
    "cooldown",
    "customise",
    "generalised",
    "goroutines",
    "indeterministically",
    "initialised",
    "intialise",
    "iteractivity",
    "optimisation",
    "optimisations",
    "optimise",
    "optimised",
    "optimiser",
    "serialisation",
    "serialise",
    "serialising",
    "spellbook",
    "Strikethrough",
    "summarise",
    "summarises",
    "timespan",
    "tokeniser",
    "uncoloured",
    "unsynchronised"
  ],
  "window.zoomLevel": 1,
  "explorer.confirmDragAndDrop": false,
  "workbench.editor.empty.hint": "hidden",
  "redhat.telemetry.enabled": true,
  "editor.wordWrapColumn": 110,
  "workbench.startupEditor": "none",
  "debug.onTaskErrors": "debugAnyway",
  "gopls": {
    "ui.semanticTokens": false // makes printf look sad
  },
  "go.formatTool": "goimports",
  "go.lintTool": "golangci-lint",
  "gitlens.currentLine.enabled": false,
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.enabled": false,
  "go.toolsManagement.autoUpdate": true,
  "terminal.integrated.shellIntegration.enabled": false,
  "debug.autoExpandLazyVariables": "off",
  "chat.commandCenter.enabled": false,
  "security.allowedUNCHosts": [
    "wsl.localhost"
  ],
  "chat.agent.enabled": false,
  "workbench.commandPalette.showAskInChat": false,
  "chat.checkpoints.enabled": false,
  "chat.customAgentInSubagent.enabled": false,
  "chat.agent.thinking.generateTitles": false,
  "chat.viewSessions.enabled": false,
  "chat.extensionTools.enabled": false,
  "chat.tools.autoExpandFailures": false,
  "chat.tools.terminal.enableAutoApprove": false,
  "chat.tools.renameTool.enabled": false,
  "chat.tools.usagesTool.enabled": false,
  "inlineChat.askInChat": false,
  "inlineChat.fixDiagnostics": false,
  "inlineChat.enableV2": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
}